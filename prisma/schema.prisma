generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  name               String
  image              String?
  password           String
  birthDate          DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  achievements       UserAchievement[]
  comments           Comment[]
  followers          Follows[]           @relation("following")
  following          Follows[]           @relation("follower")
  reviews            Review[]
  watchHistory       WatchHistory[]
  watchPartyMessages WatchPartyMessage[]
  watchPartyRooms    WatchPartyRoom[]    @relation("WatchPartyHost")
  watchlists         Watchlist[]
}

model Follows {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    Int
  animeId   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([animeId, createdAt])
  @@index([userId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    Int
  animeId   Int
  rating    Int
  text      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        Int
  achievementId String
  unlockedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model WatchHistory {
  userId          Int
  animeId         Int
  episodesWatched Int      @default(0)
  totalAvailable  Int?     @default(0)
  lastTime        Int      @default(0)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, animeId])
  @@index([animeId])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    Int
  animeId   Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@index([animeId])
}

model WatchPartyRoom {
  id             String              @id @default(cuid())
  animeId        Int
  hostId         Int
  title          String
  description    String?
  startsAt       DateTime?
  isOpen         Boolean             @default(true)
  lastActivityAt DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  host           User                @relation("WatchPartyHost", fields: [hostId], references: [id], onDelete: Cascade)
  messages       WatchPartyMessage[]

  @@index([animeId, lastActivityAt])
  @@index([hostId, createdAt])
}

model WatchPartyMessage {
  id        String         @id @default(cuid())
  roomId    String
  userId    Int
  content   String
  createdAt DateTime       @default(now())
  room      WatchPartyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId, createdAt])
}
